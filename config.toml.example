[schedule]
# Hours (0-23) at which the script should run
times = [8, 12, 18]

[model]
# OpenRouter model.
# Note that reasoning models are not supported due to model-specific https response formats keys
# Suggested models:
#   "google/gemini-2.0-flash-lite-001"   (very cheap, fast)
#   "anthropic/claude-haiku-4-5"         (good + cheap)
#   "meta-llama/llama-3.1-8b-instruct"  (free on OpenRouter)
id = "google/gemini-2.0-flash-lite-001"

[network]
# Number of retries on connection errors (0 = no retry)
retries = 2

[assistant]
# Shared context for all searches (optional)
common_prompt = "I'm looking for used items in good condition at fair prices."

# Optional global defaults for all searches.
# Each can be overridden per [[searches]] block, or omitted entirely (built-in defaults apply).
# Built-in defaults: deep_eval = false, max_price = unset (model is told there is no price limit)
#
# deep_eval: if false, evaluates listings from the search overview page only.
#            if true, fetches the detail page for a more precise second evaluation step.
#            true causes more https requests and openrouter token usage.
# deep_eval = false
# max_price = 0

# Searches – add as many [[searches]] blocks as needed
# Required: url - just hop on Kleinanzeigen and create the search you need.
# Add the location filter on the website, if you want one.
# Optional: max_price, deep_eval (override global above), addition_prompt
[[searches]]
url = "https://www.kleinanzeigen.de/s-beispiel/k0"
max_price = 500
deep_eval = true
addition_prompt = "Enter evaluation criteria here, e.g. size, condition, model."

[[searches]]
url = "https://www.kleinanzeigen.de/s-anderes-beispiel/k0"
# max_price and deep_eval not set → inherits from [assistant] if set, else built-in defaults
addition_prompt = "Another search with different criteria."
